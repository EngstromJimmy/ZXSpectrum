<Project Sdk="Microsoft.NET.Sdk.BlazorWebAssembly">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
	  <RunAOTCompilation>true</RunAOTCompilation>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <LocalCurrahRomPath>$(USERPROFILE)\Downloads\CURRAH.ROM</LocalCurrahRomPath>
    <GeneratedCurrahRomPath>$(MSBuildProjectDirectory)\wwwroot\Roms\CURRAH.ROM</GeneratedCurrahRomPath>
    <LocalSp0256RomPath>$(USERPROFILE)\Downloads\al2.bin</LocalSp0256RomPath>
    <GeneratedSp0256RomPath>$(MSBuildProjectDirectory)\wwwroot\Roms\SP0256-AL2.BIN</GeneratedSp0256RomPath>
  </PropertyGroup>

  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Debug|AnyCPU'">
    <DefineConstants>DEBUG;TRACE</DefineConstants>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.Components.WebAssembly" Version="10.0.0" />
    <PackageReference Include="Microsoft.AspNetCore.Components.WebAssembly.DevServer" Version="10.0.0" PrivateAssets="all" />
    <PackageReference Include="SkiaSharp.Views.Blazor" Version="3.119.1" />
    
    <PackageReference Include="System.Net.Http.Json" Version="10.0.0" />
    <PackageReference Include="Toolbelt.Blazor.Gamepad" Version="9.0.0" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\ZXBox.Core\ZXBox.Core.csproj" />
  </ItemGroup>

  <Target Name="SyncLocalSpeechRoms" BeforeTargets="ResolveProjectStaticWebAssets">
    <MakeDir Directories="$(MSBuildProjectDirectory)\wwwroot\Roms" />
    <Copy SourceFiles="$(LocalCurrahRomPath)"
          DestinationFiles="$(GeneratedCurrahRomPath)"
          SkipUnchangedFiles="true"
          Condition="Exists('$(LocalCurrahRomPath)')" />
    <Copy SourceFiles="$(LocalSp0256RomPath)"
          DestinationFiles="$(GeneratedSp0256RomPath)"
          SkipUnchangedFiles="true"
          Condition="Exists('$(LocalSp0256RomPath)')" />
    <Delete Files="$(GeneratedCurrahRomPath)"
            Condition="!Exists('$(LocalCurrahRomPath)') and Exists('$(GeneratedCurrahRomPath)')" />
    <Delete Files="$(GeneratedSp0256RomPath)"
            Condition="!Exists('$(LocalSp0256RomPath)') and Exists('$(GeneratedSp0256RomPath)')" />
  </Target>

  <Target Name="CopyLocalSpeechRomsToOutput"
          AfterTargets="Build"
          DependsOnTargets="SyncLocalSpeechRoms">
    <MakeDir Directories="$(TargetDir)wwwroot\Roms" Condition="'$(TargetDir)' != ''" />
    <Copy SourceFiles="$(GeneratedCurrahRomPath)"
          DestinationFiles="$(TargetDir)wwwroot\Roms\CURRAH.ROM"
          SkipUnchangedFiles="true"
          Condition="'$(TargetDir)' != '' and Exists('$(GeneratedCurrahRomPath)')" />
    <Copy SourceFiles="$(GeneratedSp0256RomPath)"
          DestinationFiles="$(TargetDir)wwwroot\Roms\SP0256-AL2.BIN"
          SkipUnchangedFiles="true"
          Condition="'$(TargetDir)' != '' and Exists('$(GeneratedSp0256RomPath)')" />
    <Delete Files="$(TargetDir)wwwroot\Roms\CURRAH.ROM"
            Condition="'$(TargetDir)' != '' and !Exists('$(GeneratedCurrahRomPath)') and Exists('$(TargetDir)wwwroot\Roms\CURRAH.ROM')" />
    <Delete Files="$(TargetDir)wwwroot\Roms\SP0256-AL2.BIN"
            Condition="'$(TargetDir)' != '' and !Exists('$(GeneratedSp0256RomPath)') and Exists('$(TargetDir)wwwroot\Roms\SP0256-AL2.BIN')" />
  </Target>

  <ItemGroup>
    <Content Update="wwwroot\css\zx.ttf">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <Content Update="wwwroot\images\48.png">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <Content Update="wwwroot\images\ZXSpectrum+2.png">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <Content Update="wwwroot\images\ZXSpectrum+3.png">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <Content Update="wwwroot\images\ZXSpectrum128k.png">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <Content Update="wwwroot\images\ZXSpectrum48k.png">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <Content Update="wwwroot\images\zxwallpaper.png">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <Content Update="wwwroot\Roms\ManicMiner.z80.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

</Project>
